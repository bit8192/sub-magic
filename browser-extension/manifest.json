{
	"manifest_version": 3,
	"name": "Sub Magic",
	"version": "1.0.3",
	"description": "查看当前站点路由链路、切换代理与 IpCheck，并快速写回 Mihomo/Sub Magic 规则",
	"browser_specific_settings": {
		"gecko": {
			"id": "bit16@qq.com",
			"strict_min_version": "128.0",
			"data_collection_permissions": {
				"required": ["none"]
			}
		}
	},
	"permissions": ["storage", "activeTab", "tabs", "webRequest", "proxy"],
	"host_permissions": ["<all_urls>"],
	"icons": {
		"16": "icons/icon.svg",
		"48": "icons/icon.svg",
		"128": "icons/icon.svg"
	},
	"action": {
		"default_title": "Sub Magic",
		"default_popup": "src/popup/popup.html",
		"default_icon": "icons/icon.svg"
	},
	"options_ui": {
		"page": "src/options/options.html",
		"open_in_tab": false
	},
	"background": {
		"scripts": ["src/background/background.js"]
	}
}
