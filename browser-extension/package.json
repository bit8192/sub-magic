{
	"name": "sub-magic-extension",
	"version": "1.0.3",
	"private": true,
	"description": "Sub Magic browser extension for routing inspection, proxy control, IpCheck, and Mihomo rule management",
	"scripts": {
		"sync-icon": "node ../scripts/sync-icons.js",
		"build": "node scripts/build.js",
		"sign:firefox": "source ./.env && npx web-ext sign --source-dir=./ --api-key=\"$FIREFOX_API_KEY\" --api-secret=\"$FIREFOX_API_SECRET\" --channel=unlisted"
	},
	"devDependencies": {
		"web-ext": "^8.0.0"
	}
}
